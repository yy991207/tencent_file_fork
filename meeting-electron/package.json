{
  "name": "meeting-electron",
  "version": "1.0.0",
  "private": true,
  "description": "腾讯会议白板 - Electron 桌面端",
  "main": "dist/main/index.js",
  "scripts": {
    "dev": "vite --config packages/renderer/vite.config.ts --port 5174 --strictPort",
    "dev:electron": "npm run build:main && npm run build:preload && concurrently \"npm run dev\" \"wait-on http://localhost:5174 && NODE_ENV=development DEV_PORT=5174 npx electron .\"",
    "build:renderer": "vite build --config packages/renderer/vite.config.ts",
    "build:main": "tsc -p packages/main/tsconfig.json",
    "build:preload": "tsc -p packages/preload/tsconfig.json",
    "build": "npm run build:renderer && npm run build:main && npm run build:preload",
    "pack": "npm run build && electron-builder",
    "postinstall": "electron-builder install-app-deps"
  },
  "dependencies": {
    "@tencentcloud/roomkit-electron-vue3": "^3.2.4",
    "@tencentcloud/tuiroom-engine-electron": "^4.0.1",
    "vue": "^3.5.0",
    "vue-router": "^4.5.0",
    "pinia": "2.0.24"
  },
  "devDependencies": {
    "electron": "~33.3.0",
    "electron-builder": "^25.1.0",
    "vite": "^6.0.0",
    "@vitejs/plugin-vue": "^5.2.0",
    "typescript": "^5.7.0",
    "vue-tsc": "^2.2.0",
    "concurrently": "^9.1.0",
    "wait-on": "^8.0.0"
  }
}
