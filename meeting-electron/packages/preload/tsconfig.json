{
  "compilerOptions": {
    "target": "ES2022",
    "module": "commonjs",
    "moduleResolution": "node",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "outDir": "../../dist/preload",
    "rootDir": ".",
    "declaration": false,
    "sourceMap": true
  },
  "include": ["./**/*.ts"]
}
